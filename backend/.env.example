# SmartHRMS Backend Environment Variables
PORT=5000

# Google Gemini API configuration
# Paste your Gemini API Key here to power live resume screening, voice interviewer evaluations, and HR Chatbot replies.
# If left empty, the application runs on high-fidelity local AI simulators for zero-setup demo testing.
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for Session Authentication
JWT_SECRET=your_jwt_secret_token_here

# MongoDB Connection URI
MONGODB_URI=your_mongodb_connection_uri_here
