# SmartHRMS Backend Environment Variables
PORT=5000

# Google Gemini API configuration
# Paste your Gemini API Key here to power live resume screening, voice interviewer evaluations, and HR Chatbot replies.
# If left empty, the application runs on high-fidelity local AI simulators for zero-setup demo testing.
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Secret for Session Authentication
JWT_SECRET=your_jwt_secret_token_here

# MongoDB Connection URI (required for Vercel — local db.json does not work on serverless)
# Create a free cluster at https://cloud.mongodb.com and paste the connection string here.
# In MongoDB Atlas → Network Access → allow 0.0.0.0/0 for Vercel serverless IPs.
MONGODB_URI=your_mongodb_connection_uri_here

# Frontend URL for CORS (your Vercel frontend URL, e.g. https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5173
